{
  "name": "@slidesjs/vite",
  "version": "0.0.0",
  "description": "Vite plugin that compiles Markdown and MDX deck files into slidesjs slides.",
  "type": "module",
  "license": "MIT",
  "files": ["dist"],
  "main": "./dist/index.js",
